rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /facts/{factId} {
      allow read: if true;
      allow create: if isValidFact();
      // редактировать и удалять факты можно только из консоли Firebase
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isValidFact() {
      let d = request.resource.data;
      return d.keys().hasOnly(['tag', 'text', 'author', 'authorLink', 'image', 'createdAt'])
        && d.keys().hasAll(['tag', 'text', 'author', 'authorLink', 'image', 'createdAt'])
        && d.tag is string && d.tag.size() >= 2 && d.tag.size() <= 60 && d.tag.matches('#.+')
        && d.text is string && d.text.size() >= 1 && d.text.size() <= 1000
        && (d.author == null || (d.author is string && d.author.size() >= 1 && d.author.size() <= 100))
        && (d.authorLink == null || (d.authorLink is string && d.authorLink.size() <= 300 && d.authorLink.matches('https?://.+')))
        && (d.image == null || (d.image is string && d.image.size() <= 800 && d.image.matches('https://firebasestorage[.]googleapis[.]com/.+')))
        && d.createdAt == request.time;
    }
  }
}
